<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_quick_2x4_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="18dp">

    <!-- Header Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TaskFlow Studio"
            android:textColor="#A1A1AA"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25m • 5m • 15m"
            android:textColor="#71717A"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Center: Pomodoro Studio Area -->
    <LinearLayout
        android:id="@+id/btn_pomodoro_2x4"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pomodoro focus session"
            android:textColor="#A1A1AA"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/text_pomodoro_status_2x4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="25:00"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Bottom: Quick Add Task Strip -->
    <LinearLayout
        android:id="@+id/btn_add_task_2x4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_btn_minimal_add"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ New Task"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_task_count_2x4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to create instantly"
            android:textColor="#A1A1AA"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
